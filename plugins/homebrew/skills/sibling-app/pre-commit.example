#!/usr/bin/env bash
# Pre-commit gate — runs only the checks relevant to what's staged. Installed by
# ./install-hooks.sh (sets core.hooksPath). Git runs it from the repo root.
#
# COMMIT THIS FILE WITH MODE 755 (see install-hooks.sh). Git SILENTLY SKIPS a
# non-executable core.hooksPath hook — the gate looks installed but never fires.
# Verify: `git ls-files -s .githooks` → mode must read 100755.
set -euo pipefail

staged="$(git diff --cached --name-only --diff-filter=ACMR)"
[ -n "$staged" ] || exit 0

run_front=0
run_rust=0
while IFS= read -r f; do
	case "$f" in
		frontend/* | package.json | yarn.lock | .yarnrc.yml) run_front=1 ;;
	esac
	case "$f" in
		backend/* | shared/* | e2e/* | Cargo.toml | Cargo.lock) run_rust=1 ;;
	esac
	# Add a branch per extra Rust crate / non-Rust sidecar, e.g.:
	# case "$f" in <worker>/* ) run_rust=1 ;; esac
	# case "$f" in <shim>/*.py | <shim>/pyproject.toml ) run_shim=1 ;; esac
done <<<"$staged"

if [ "$run_front" = 1 ]; then
	echo "pre-commit: frontend (lint + format)"
	# Vendored yarn (no corepack), invoked via node.
	node .yarn/releases/yarn-*.cjs lint
	node .yarn/releases/yarn-*.cjs format
fi

if [ "$run_rust" = 1 ]; then
	echo "pre-commit: rust (clippy, whole workspace)"
	cargo clippy --workspace --all-targets -- -D warnings
fi

# if [ "${run_shim:-0}" = 1 ]; then
# 	echo "pre-commit: python sidecar (ruff)"
# 	( cd <shim> && uv run ruff check src )
# fi

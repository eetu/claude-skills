import { sveltekit } from "@sveltejs/kit/vite";
import { defineConfig } from "vite";

// Vite dev server (:5173). Output goes to dist/ (wired in svelte.config.js via
// adapter-static), which the Rust backend embeds/serves in prod — same-origin
// either way. In dev, proxy the backend's routes so the SPA is same-origin too.
export default defineConfig({
  plugins: [sveltekit()],
  server: {
    // The backend listens on :3010 (<APP>_BIND default). Proxy only its real
    // routes. NOTE: /auth is the oauth2-proxy EDGE route, NOT a backend route —
    // don't add a backend /auth handler; locally PARTY_OPEN=1 / DEV_AUTH bypass
    // forward-auth so you never hit it in dev.
    proxy: {
      "/api": "http://localhost:3010",
      "/status": "http://localhost:3010",
    },
  },
});

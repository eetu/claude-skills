# One Rust workspace for every backend/service crate. Crates share this
# [workspace.dependencies] table, one Cargo.lock, and one target/. Replace
# <app> with the lowercase app name (e.g. tracker); add more members (a worker,
# a second service) under members as the app grows — same shape, own binary.
[workspace]
resolver = "2"
members = [
    "backend",
    "e2e",
    # "<worker>",   # optional: another service crate, same shape
]

[workspace.package]
edition = "2021"
version = "0.1.0"

# Versionless intent: take the latest of each at scaffold time (`cargo add`),
# then pin. Majors shown are a known-good baseline — bump freely.
[workspace.dependencies]
axum = { version = "0.8", features = ["macros", "tokio", "tracing"] }
axum-extra = { version = "0.10", features = ["cookie", "cookie-signed", "typed-header"] }
tokio = { version = "1", features = ["full"] }
tower-http = { version = "0.7", features = ["fs", "set-header", "trace", "cors"] }
reqwest = { version = "0.12", default-features = false, features = ["json", "rustls-tls"] }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
thiserror = "2"
anyhow = "1"
tracing = "0.1"
tracing-subscriber = { version = "0.3", features = ["env-filter"] }
chrono = { version = "0.4", features = ["serde"] }
uuid = { version = "1", features = ["v4"] }
url = "2"
hex = "0.4"
dotenvy = "0.15"
mime_guess = "2"
rusqlite = { version = "0.40", features = ["bundled"] }   # omit if stateless
# openidconnect = "4"   # only if the app does its own OIDC (usually not —
#                       # it sits behind oauth2-proxy; see the auth extractor)
# subtle = "2"          # constant-time compare for service-to-service tokens

[workspace.dependencies.tempfile]
version = "3"           # dev-dep: temp SQLite + temp dist/ in the e2e harness

[workspace.dependencies.wiremock]
version = "0.6"         # dev-dep: stub HTTP upstreams for a fan-in app

# EditorConfig — https://editorconfig.org
# Copy to a repo root as `.editorconfig`. One file = the cross-language source of
# truth for indentation, line width, and newline/charset hygiene. Prettier reads
# it (indent_style, indent_size/tab_width, max_line_length, end_of_line); most
# editors read it natively; rustfmt/gofmt ignore it but already match these.
# Trim the language blocks the repo doesn't use.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2
# Prettier's default is 80. Line width is the one knob most repos override; set it
# here once and every editor + Prettier follows. Delete the line to keep 80.
max_line_length = 100

# Rust (rustfmt) and Python (PEP 8) indent with 4 spaces.
[*.{rs,py}]
indent_size = 4

# Go (gofmt) and Makefile recipes require literal tabs.
[*.go]
indent_style = tab

[Makefile]
indent_style = tab

# Markdown keeps trailing whitespace (two trailing spaces = a hard line break).
[*.md]
trim_trailing_whitespace = false

# YAML inherits spaces from [*] above — never set it to tabs (illegal in YAML).
